# Database — Neon PostgreSQL (бесплатно: neon.tech)
# DATABASE_URL — pooled connection (для запросов)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/agronom?sslmode=require"
# DATABASE_URL_UNPOOLED — прямое подключение (для миграций)
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/agronom?sslmode=require"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_WEBHOOK_SECRET="your-random-secret-here"

# App URL (для Telegram webhook)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_URL="https://your-app.vercel.app" # для Vercel

# Cron secret (для защиты cron endpoint)
CRON_SECRET="your-cron-secret-here"
